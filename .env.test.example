# Test Environment Configuration
# Copy this file to .env.test and update values

# Database Configuration
# Option 1: PostgreSQL (via Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mocktest_auth

# Option 2: SQLite (for quick local testing)
# DATABASE_URL=sqlite+aiosqlite:///./test.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security Keys
SECRET_KEY=test-secret-key-change-in-production
SESSION_SECRET=test-session-secret-change-in-production

# Optional: RS256 Keys for JWT (if not set, will use HS256)
# RS256_PRIVATE_KEY=
# RS256_PUBLIC_KEY=

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=testing
LOG_LEVEL=INFO

# Security Settings
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15

# Exam Settings
MAX_EXAM_DURATION_HOURS=3
EXAM_GRACE_PERIOD_MINUTES=10

# Rate Limiting
RATE_LIMIT_ENABLED=true

# CORS
BACKEND_CORS_ORIGINS=["*"]
